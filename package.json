{
  "name": "bun-backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "daloy dev --runtime bun",
    "start": "bun src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "gen:openapi": "bun run scripts/dump-openapi.ts",
    "gen:client": "openapi-ts",
    "gen": "bun run gen:openapi && bun run gen:client",
    "audit": "bun audit --prod"
  },
  "dependencies": {
    "@daloyjs/core": "^0.38.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.1",
    "@types/bun": "^1.1.0",
    "typescript": "^6.0.3"
  }
}
